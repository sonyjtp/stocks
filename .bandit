[bandit]
# Bandit security configuration
exclude_dirs = ['/tests', '/venv', '/.venv']
tests = [B201, B301, B302, B303, B304, B305, B306, B307, B308, B309, B310, B311, B312, B313, B314, B315, B316, B317, B318, B319, B320, B321, B322, B323, B324, B325]

# Severity level: LOW, MEDIUM, HIGH
severity = MEDIUM

# Confidence level: LOW, MEDIUM, HIGH
confidence = MEDIUM

# Skips - specific tests to skip
skip_ids = []
