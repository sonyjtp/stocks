# Database Configuration
DATABASE_URL=postgresql+psycopg://stocks_user:stocks_password@localhost:5436/stocks_db

# Docker PostgreSQL Credentials (used by docker-compose.yml)
POSTGRES_USER=stocks_user
POSTGRES_PASSWORD=stocks_password
POSTGRES_DB=stocks_db

# Redis Cache Configuration
REDIS_URL=redis://localhost:6380

# Frontend Configuration
FRONTEND_URL_1=http://localhost:5174
FRONTEND_URL_2=http://localhost:3000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8765
API_TITLE=Stock Trading Tracker API
API_ENVIRONMENT=development

# Logging Configuration
LOG_LEVEL=INFO

# Security Configuration
CORS_CREDENTIALS=true
ALLOW_METHODS=*
ALLOW_HEADERS=*

# Optional: External API Keys (if needed in future)
# POLYGON_API_KEY=your_key_here
# ALPHA_VANTAGE_API_KEY=your_key_here
